<% layout('/layouts/boilerplate') -%>

<div id="filters">
  <a href="/listings<%= searchQuery ? `?q=${encodeURIComponent(searchQuery)}` : '' %>" class="filter-link">
    <div class="filter <%= activeCategory === '' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-border-all"></i></div>
      <p>All</p>
    </div>
  </a>

  <% for (const filter of filters) { %>
    <a href="/listings?category=<%= filter.slug %><%= searchQuery ? `&q=${encodeURIComponent(searchQuery)}` : '' %>" class="filter-link">
      <div class="filter <%= activeCategory === filter.slug ? 'active-filter' : '' %>">
        <div><i class="<%= filter.icon %>"></i></div>
        <p><%= filter.label %></p>
      </div>
    </a>
  <% } %>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
  <div>
    <% if (activeCategory) { %>
      <span class="badge rounded-pill text-bg-dark">Filtered</span>
    <% } %>
    <% if (searchQuery) { %>
      <span class="badge rounded-pill text-bg-secondary">Search: <%= searchQuery %></span>
    <% } %>
  </div>
  <p class="text-muted m-0"><%= resultCount %> listing(s) found</p>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-2 g-4">
  <% if (allListings.length === 0) { %>
    <div class="col-12">
      <div class="alert alert-secondary">No listings matched your search or filter.</div>
    </div>
  <% } %>

  <% for (const listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card h-100">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem; object-fit: cover;" />
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text mb-1"><b><%= listing.title %></b></p>
            <p class="card-text text-muted mb-1"><%= listing.location %>, <%= listing.country %></p>
            <p class="card-text mb-0">
              &#8377; <%= listing.price.toLocaleString('en-IN') %> / night
              <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  const taxSwitch = document.getElementById('switchCheckDefault');
  if (taxSwitch) {
    taxSwitch.addEventListener('click', () => {
      const taxInfo = document.getElementsByClassName('tax-info');
      const showTax = taxSwitch.checked;
      for (const info of taxInfo) {
        info.style.display = showTax ? 'inline' : 'none';
      }
    });
  }
</script>
